# =============================================================
# Nexus Recall — Environment Configuration
# =============================================================

# --- Nexus Recall Core (required for API server) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/nexusrecall
REDIS_URL=redis://localhost:6379
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=text-embedding-3-small
OPENROUTER_API_KEY=sk-or-...
# NANOGPT_API_KEY=...

# --- Nexus Recall API Server ---
NEXUS_RECALL_API_PORT=3200

# --- Harness: LLM Provider ---
LLM_PROVIDER=openrouter
LLM_OPENROUTER_API_KEY=sk-or-...
LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_OPENROUTER_MODEL=openai/gpt-4o-mini
# LLM_NANOGPT_API_KEY=...
# LLM_NANOGPT_BASE_URL=https://nano-gpt.com/api/v1
# LLM_NANOGPT_MODEL=...

# --- Harness: Generation Defaults ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# --- Harness: Server ---
HARNESS_PORT=3100
NEXUS_RECALL_URL=http://localhost:3200

# --- Harness: Optional ---
# DEFAULT_PERSONA_PROMPT=You are a helpful assistant.
# HARNESS_DEBUG=true
